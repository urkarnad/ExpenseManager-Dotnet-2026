<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ExpensesManager.MyMauiApp.Pages.TransactionDetailsPage"
             Title="Transaction Details"
             BackgroundColor="#FFF0F5">
    <VerticalStackLayout Padding="24" Spacing="16">

        <Label Text="🧾 Transaction Details"
               FontSize="26"
               FontAttributes="Bold"
               TextColor="#C2185B"
               HorizontalOptions="Center"
               Margin="0,10,0,10"/>

        <Frame BackgroundColor="White"
               CornerRadius="20"
               Padding="24"
               BorderColor="#F48FB1"
               HasShadow="True">
            <VerticalStackLayout Spacing="14">

                <HorizontalStackLayout Spacing="10">
                    <Label Text="💰" FontSize="22"/>
                    <Label Text="{Binding Transaction.Amount, StringFormat='Amount: {0:F2}'}"
                           FontSize="18"
                           TextColor="#880E4F"
                           FontAttributes="Bold"/>
                </HorizontalStackLayout>

                <BoxView HeightRequest="1" BackgroundColor="#F8BBD0"/>

                <HorizontalStackLayout Spacing="10">
                    <Label Text="🏷️" FontSize="22"/>
                    <Label Text="{Binding Transaction.Category, StringFormat='Category: {0}'}"
                           FontSize="18"
                           TextColor="#555"/>
                </HorizontalStackLayout>

                <BoxView HeightRequest="1" BackgroundColor="#F8BBD0"/>

                <HorizontalStackLayout Spacing="10">
                    <Label Text="📝" FontSize="22"/>
                    <Label Text="{Binding Transaction.Description, StringFormat='Description: {0}'}"
                           FontSize="18"
                           TextColor="#555"/>
                </HorizontalStackLayout>

                <BoxView HeightRequest="1" BackgroundColor="#F8BBD0"/>

                <HorizontalStackLayout Spacing="10">
                    <Label Text="📅" FontSize="22"/>
                    <Label Text="{Binding Transaction.Date, StringFormat='Date: {0:dd.MM.yyyy}'}"
                           FontSize="18"
                           TextColor="#555"/>
                </HorizontalStackLayout>

            </VerticalStackLayout>
        </Frame>

    </VerticalStackLayout>
</ContentPage>