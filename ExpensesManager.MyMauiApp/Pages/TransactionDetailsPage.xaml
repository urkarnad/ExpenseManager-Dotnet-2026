<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ExpensesManager.MyMauiApp.Pages.TransactionDetailsPage"
             Title="Transaction Details">
    <VerticalStackLayout Padding="20" Spacing="15">
        <Label Text="{Binding Transaction.Amount, StringFormat='Amount: {0:F2}'}" FontSize="20"/>
        <Label Text="{Binding Transaction.Category, StringFormat='Category: {0}'}" FontSize="18"/>
        <Label Text="{Binding Transaction.Date, StringFormat='Date: {0:dd.MM.yyyy}'}" FontSize="18"/>
    </VerticalStackLayout>
</ContentPage>