<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ExpensesManager.MyMauiApp.Pages.WalletDetailsPage"
             Title="Wallet Details">
    <VerticalStackLayout Padding="20" Spacing="10">
        <Label Text="{Binding Wallet.Name}" FontSize="26" FontAttributes="Bold"/>
        <Label Text="{Binding Wallet.Amount, StringFormat='Balance: {0:F2}'}" FontSize="18" TextColor="Green"/>
        <Label Text="Transactions" FontSize="22" FontAttributes="Bold"/>
        <CollectionView
            ItemsSource="{Binding Transactions}"
            SelectionMode="Single"
            SelectionChangedCommand="{Binding SelectTransactionCommand}"
            SelectionChangedCommandParameter="{Binding SelectedItem, Source={RelativeSource Self}}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Padding="10" Margin="5">
                        <VerticalStackLayout>
                            <Label Text="{Binding Amount, StringFormat='Amount: {0:F2}'}" FontSize="16"/>
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>
</ContentPage>