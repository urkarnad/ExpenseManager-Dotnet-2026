<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ExpensesManager.MyMauiApp.Pages.WalletDetailsPage"
             Title="Wallet Details"
             BackgroundColor="#FFF0F5">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="12">

            <Frame BackgroundColor="#F8BBD0"
                   CornerRadius="20"
                   Padding="20"
                   BorderColor="#F48FB1"
                   HasShadow="True">
                <VerticalStackLayout Spacing="6">
                    <Label Text="{Binding Wallet.Name}"
                           FontSize="26"
                           FontAttributes="Bold"
                           TextColor="#880E4F"/>
                    <Label Text="{Binding Wallet.Amount, StringFormat='Balance: {0:F2}'}"
                           FontSize="20"
                           TextColor="#C2185B"
                           FontAttributes="Bold"/>
                </VerticalStackLayout>
            </Frame>

            <Label Text="Transactions"
                   FontSize="22"
                   FontAttributes="Bold"
                   TextColor="#C2185B"
                   Margin="0,10,0,0"/>

            <CollectionView
                ItemsSource="{Binding Transactions}"
                SelectionMode="Single"
                SelectionChangedCommand="{Binding SelectTransactionCommand}"
                SelectionChangedCommandParameter="{Binding SelectedItem, Source={RelativeSource Self}}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame BackgroundColor="White"
                               CornerRadius="14"
                               Padding="16,12"
                               Margin="0,5"
                               BorderColor="#F8BBD0"
                               HasShadow="True">
                            <HorizontalStackLayout Spacing="12">
                                <Label Text="💸" FontSize="22" VerticalOptions="Center"/>
                                <VerticalStackLayout VerticalOptions="Center">
                                    <Label Text="{Binding Amount, StringFormat='Amount: {0:F2}'}"
                                           FontSize="16"
                                           FontAttributes="Bold"
                                           TextColor="#880E4F"/>
                                </VerticalStackLayout>
                            </HorizontalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>